# ============================================
# Deep Research System 环境变量配置示例
# ============================================
# 复制此文件为 .env 并填写实际值
# 注意：此文件包含敏感信息，不要提交到版本控制

# ====================
# 应用基础配置
# ====================

# 应用环境
ENVIRONMENT=development  # development, testing, production

# 应用名称和版本
PROJECT_NAME=Deep Research System
VERSION=0.1.0

# 服务器配置
HOST=0.0.0.0
PORT=8000
RELOAD=true
LOG_LEVEL=info

# API 配置
API_V1_STR=/api/v1
DOCS_ENABLED=true

# CORS 配置
BACKEND_CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# ====================
# 数据库配置
# ====================

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_SSL=false

# 数据库连接池
REDIS_POOL_MIN_SIZE=1
REDIS_POOL_MAX_SIZE=10

# ====================
# AI 模型配置 (国产模型，兼容 OpenAI 接口)
# ====================

# DeepSeek (深度求索)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=8192
DEEPSEEK_TEMPERATURE=0.7

# 智谱AI (GLM)
ZHIPU_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ZHIPU_API_BASE=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4
ZHIPU_MAX_TOKENS=8192
ZHIPU_TEMPERATURE=0.7

# 月之暗面 (Kimi)
KIMI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
KIMI_API_BASE=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k
KIMI_MAX_TOKENS=8192
KIMI_TEMPERATURE=0.7

# 豆包 (ByteDance)
DOUBAO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DOUBAO_API_BASE=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=ep-20240610112120-abcdefg
DOUBAO_MAX_TOKENS=4096
DOUBAO_TEMPERATURE=0.7

# 百度文心一言 (ERNIE)
ERNIE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ERNIE_API_BASE=https://aip.baidubce.com/rpc/2.0/ai_custom/v1/wenxinworkshop
ERNIE_MODEL=ernie-4.0-8k
ERNIE_MAX_TOKENS=8192
ERNIE_TEMPERATURE=0.7

# 阿里通义千问 (Qwen)
QWEN_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-max
QWEN_MAX_TOKENS=8192
QWEN_TEMPERATURE=0.7

# ====================
# 搜索服务配置
# ====================

# Serper API (Google 搜索)
SERPER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Tavily AI 搜索
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google 自定义搜索
GOOGLE_CSE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_API_KEY_FOR_SEARCH=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ====================
# 向量数据库配置
# ====================

# Pinecone
PINECONE_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PINECONE_ENVIRONMENT=gcp-starter
PINECONE_INDEX_NAME=deep-research-index

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Chroma
CHROMA_PERSIST_DIRECTORY=./chroma_db
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ====================
# 安全配置
# ====================

# JWT 配置
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API 限流
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ====================
# 外部 API 服务
# ====================

# GitHub API (用于代码搜索)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ArXiv API (用于学术论文搜索)
ARXIV_EMAIL=your-email@example.com

# Wikipedia API
WIKIPEDIA_USER_AGENT=DeepResearchSystem/0.1.0 (your-email@example.com)

# ====================
# 日志和监控
# ====================

# Sentry (错误监控)
SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@sentry.io/xxxxxxx

# Logtail (日志收集)
LOGTAIL_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Prometheus (指标监控)
PROMETHEUS_PORT=9090

# ====================
# 文件存储
# ====================

# 本地文件存储
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=104857600  # 100MB

# AWS S3 (可选)
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_REGION=us-east-1
AWS_S3_BUCKET=deep-research-system

# ====================
# 邮件服务
# ====================

# SMTP 配置
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM=your-email@gmail.com

# ====================
# 任务队列
# ====================

# Celery (异步任务)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ====================
# 缓存配置
# ====================

# 默认缓存时间 (秒)
CACHE_TTL=3600  # 1小时

# 搜索结果缓存
SEARCH_CACHE_TTL=1800  # 30分钟

# 模型响应缓存
MODEL_CACHE_TTL=86400  # 24小时

# ====================
# 调试和开发
# ====================

# 调试模式
DEBUG=true

# 模拟模式 (用于测试)
MOCK_AI_RESPONSES=false
MOCK_SEARCH_RESULTS=false

# 请求超时 (秒)
REQUEST_TIMEOUT=30
MODEL_TIMEOUT=60

# ====================
# 性能配置
# ====================

# 并发限制
MAX_CONCURRENT_REQUESTS=10
MAX_CONCURRENT_SEARCHES=5

# 批处理大小
BATCH_SIZE=10

# 重试配置
MAX_RETRIES=3
RETRY_DELAY=1  # 秒

# ============================================
# 重要提示
# ============================================
# 1. 将此文件复制为 .env 并填写实际值
# 2. 永远不要将 .env 文件提交到版本控制
# 3. 生产环境使用更安全的密钥管理方式
# 4. 定期轮换 API 密钥
# 5. 使用环境变量注入而不是硬编码