# Redis
REDIS_URL=redis://localhost:6379/0

# ============================================================
# 模型配置 - 通过修改以下环境变量即可更换模型
# 所有模型需兼容 OpenAI 接口格式
# ============================================================

# 槽位 1: 搜索/阅读用模型（低成本，支持长上下文）
MODEL_SEARCH_NAME=deepseek-chat
MODEL_SEARCH_API_KEY=sk-your-api-key-here
MODEL_SEARCH_API_BASE=https://api.deepseek.com

# 槽位 2: 分析用模型（低成本，长上下文，结构化提取）
MODEL_ANALYSIS_NAME=deepseek-chat
MODEL_ANALYSIS_API_KEY=sk-your-api-key-here
MODEL_ANALYSIS_API_BASE=https://api.deepseek.com

# 槽位 3: 规划/审稿用模型（强推理能力）
MODEL_REASONING_NAME=deepseek-chat
MODEL_REASONING_API_KEY=sk-your-api-key-here
MODEL_REASONING_API_BASE=https://api.deepseek.com

# 槽位 4: 写作用模型（强写作/综合能力）
MODEL_WRITING_NAME=deepseek-chat
MODEL_WRITING_API_KEY=sk-your-api-key-here
MODEL_WRITING_API_BASE=https://api.deepseek.com

# 搜索服务
TAVILY_API_KEY=tvly-your-api-key-here

# App
APP_ENV=development
LOG_LEVEL=INFO
